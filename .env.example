# CodeShip Environment Variables

# Database & Redis Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/codeship?schema=public"
REDIS_URL="redis://localhost:6379"

# Local Docker Database Credentials (ignored by Git)
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_NAME=codeship

# Security Secrets (Generate strong ones for production)
# JWT_SECRET should be a secure random string
JWT_SECRET="codeship-local-jwt-secret-key-change-me-in-production-1234"
# ENCRYPTION_KEY must be exactly 32 characters (32 bytes) for AES-256-GCM
ENCRYPTION_KEY="codeship-secret-key-32-chars!!!"

# Domain Routing Configuration
# Dashboard domain: deploy.atharvabaodhankar.me (production) or localhost:3000 (dev)
# User apps will be served under: <project-slug>.<BASE_DOMAIN>
BASE_DOMAIN="localhost"
NEXT_PUBLIC_BASE_DOMAIN="localhost"

# GitHub OAuth App Configuration
# Create a GitHub OAuth App and paste credentials here
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"

# Deployment Configuration
PORT_RANGE_START=3001
PORT_RANGE_END=9999
BUILDS_DIR="./builds"
